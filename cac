_args=()
for arg in "$@"; do
    case "$arg" in
        /proc/1/cgroup|/proc/self/cgroup|/proc/thread-self/cgroup)
            _src="$_env_dir/cgroup_text"
            if [[ -f "$_src" ]]; then
                _tmp=$(mktemp)
