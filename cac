                _tmp_files+=("$_tmp")
                _args+=("$_tmp")
            else
                _args+=("$arg")
            fi
            ;;
        /proc/1/mountinfo|/proc/self/mountinfo|/proc/thread-self/mountinfo)
            _src="$_env_dir/mountinfo_text"
            if [[ -f "$_src" ]]; then
